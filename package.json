{
  "name": "remotion-prompt-studio",
  "version": "1.0.0",
  "description": "Prompt-based video generation studio powered by Remotion + Antigravity IDE",
  "type": "module",
  "scripts": {
    "studio": "remotion studio",
    "ui": "vite --config vite.config.ts",
    "server": "tsx watch server/server.ts",
    "start": "concurrently -n SERVER,UI -c blue,magenta \"npm run server\" \"npm run ui\"",
    "render": "remotion render",
    "build": "remotion bundle",
    "lint": "eslint src && tsc --noEmit"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/media": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@remotion/animation-utils": "^4.0.0",
    "@remotion/captions": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/transitions": "^4.0.0",
    "@remotion/zod-types": "^4.0.0",
    "chokidar": "^4.0.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dotenv": "^16.4.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "private": true
}
